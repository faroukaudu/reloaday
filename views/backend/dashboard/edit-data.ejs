                                <!-- Page-header end -->
                                    
                                    <!-- Page-body start -->
                                    <div class="page-body">
                                       
                                        <!-- Edit With Button card start -->
                                        <div class="card">
                                            <div class="card-header">
                                                <h5>Edit With Button</h5>
                                                
                                                <span>Click on buttons to perform actions</span>
                                                 

                                            </div>
                                            <div class="card-block" style="padding-left: -150px;">
                                                <div class="table-responsive">
                                                    <table class="table table-striped table-bordered" id="example-2">
                                                        <thead>
                                                            <tr>
                                                                <th>Bundle code</th>
                                                                <th>Network Name</th>
                                                                <th>Bun-Type</th>
                                                                <th>Size</th>
                                                                <th>Duration</th>
                                                                <th>Api-cost</th>
                                                                <th>cost</th>
                                                                <th>Profit</th>
                                                                <!-- <th>Action</th> -->
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <% plans.forEach(function(plan){ %>
                                                                <tr data-userid="<%= plan.bundleCode %> ">
                                                                <td class="tabledit-view-mode"><span class="tabledit-span"><%= plan.bundleCode%></span>
                                                                    <input  class="tabledit-input form-control input-sm" type="text" name="bdcode" value="<%= plan.bundleCode%>" disabled="">
                                                                </td>
                                                                
                                                                <td class="tabledit-view-mode"><span class="tabledit-span"><%= plan.networkName%></span>
                                                                    <input  class="tabledit-input form-control input-sm" type="text" name="nname" value="<%= plan.networkName%>" disabled="">
                                                                </td>
                                                                
                                                                <td class="tabledit-view-mode"><span class="tabledit-span"><%= plan.bundleType%></span>
                                                                    <input class="tabledit-input form-control input-sm" type="text" name="buntype" value="<%= plan.bundleType%>" disabled="">
                                                                </td>
                                                                <td class="tabledit-view-mode"><span class="tabledit-span"><%= plan.bundleSize%></span>
                                                                    <input class="tabledit-input form-control input-sm" type="text" name="size" value="<%= plan.bundleSize%>" disabled="">
                                                                </td>
                                                                <td class="tabledit-view-mode"><span class="tabledit-span"><%= plan.bundleDuration%></span>
                                                                    <input class="tabledit-input form-control input-sm" type="text" name="dura" value="<%= plan.bundleDuration%>" disabled="">
                                                                </td>
                                                                <td class="tabledit-view-mode"><span class="tabledit-span"> ₦<%= plan.apiAmount%></span>
                                                                    <input class="tabledit-input form-control input-sm" type="text" name="apicost" value="<%= plan.apiAmount%>" disabled="">
                                                                </td>
                                                                <td class="tabledit-view-mode"><span class="tabledit-span">₦<%= plan.amount%></span>
                                                                    <input class="tabledit-input form-control input-sm" type="text" name="cost" value="<%= plan.amount%>" disabled="">
                                                                </td>
                                                                <td>₦<%=(plan.amount- plan.apiAmount).toFixed(2)%></td>
                                                                
                                                                
                                                                

                                                                </tr>
                                                                
                                                            <% }) %>
                                                            
                                                           
                                                            
                                                            
                                                        </tbody>
                                                    </table>
                                                </div>
                                               <button type="button" class="btn btn-primary waves-effect waves-light add" onclick="add_row_example2()">
    Add Row
</button>
                                            </div>
                                        </div>
                                        <!-- Edit With Button card end -->
                                    </div>
                                    <!-- Page-body end -->
                                </div>
                            </div>
                            <!-- Main-body end -->
                            <div id="styleSelector">

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
