<%- include("../../includes/dash/head", {userInfo:userInfo}); -%>
<style>

#example-2 {
    width: 100%;
    table-layout: auto;   /* changed from fixed */
}

#example-2 th,
#example-2 td {
    vertical-align: middle;
    white-space: nowrap;
    overflow: visible;    /* changed from hidden */
    text-overflow: clip;  /* changed from ellipsis */
}

#example-2 th:last-child,
#example-2 td:last-child {
    min-width: 180px;
    width: 180px;
    overflow: visible !important;
    white-space: nowrap;
}

#example-2 td:last-child .btn {
    display: inline-block;
    margin-right: 8px;
}

#example-2 .table-responsive {
    overflow-x: auto;
}

.tabledit-input {
    text-align: left !important;
    padding-left: 6px !important;
}
</style>


</style>
